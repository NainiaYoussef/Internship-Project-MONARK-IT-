## STEP 8 — How the other developer uses your API

Give them your base URL (e.g. https://your-app.railway.app) and this usage example:

### JavaScript / React example:
```javascript
// Digitize an exam PDF
async function digitizeExam(pdfFile) {
  const formData = new FormData();
  formData.append('file', pdfFile);
  formData.append('dpi', '150');

  const response = await fetch('https://your-api-url/digitize', {
    method: 'POST',
    body: formData,
  });
  const data = await response.json();
  // data.questions = array of question objects
  // data.pages     = array of base64 PNG strings
  return data;
}

// Grade a student answer
async function gradeAnswer(stem, studentAnswer) {
  const response = await fetch('https://your-api-url/grade', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      question_stem: stem,
      student_answer: studentAnswer,
    }),
  });
  const data = await response.json();
  // data.score            = 0-20
  // data.feedback         = string
  // data.missing_concepts = array of strings
  return data;
}
```

### Python example:
```python
import requests

# Digitize
with open("exam.pdf", "rb") as f:
    r = requests.post("https://your-api-url/digitize", files={"file": f})
    data = r.json()
    print(f"Found {data['total']} questions")

# Grade
r = requests.post("https://your-api-url/grade", json={
    "question_stem": "Why do plants need nitrate ions?",
    "student_answer": "For making proteins.",
})
print(r.json())
```

